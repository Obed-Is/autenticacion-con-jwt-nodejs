<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <script src="home.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --color-primary: #2E4F40;
            --color-secondary: #1a2b22;
            --color-text: #F5F2EC;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(to right, var(--color-primary), var(--color-secondary));
            color: var(--color-text);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            width: 100%;
            min-height: 100dvh;
        }

        main {
            width: 90%;
            height: 100%;
            margin: 0 auto;
            padding: 20px;
        }

        .welcome {
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: center;
            height: 100%;
            gap: 5px;

            h1 {
                font-size: 2.5rem;
            }

            p {
                font-size: 1.2rem;
                color: var(--color-text-secondary);
            }
        }

        .state-session {
            width: fit-content;
            background: rgba(26, 43, 34, 0.6);
            border: 1px solid rgba(214, 232, 227, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            font-weight: 500;
            padding: 12px 24px;
            border-radius: 50px;
            margin: 30px 0;
        }

        #state {
            color: #4ade80;
            background: rgba(74, 222, 128, 0.1);
            padding: 6px 16px;
            border-radius: 30px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.85rem;
        }

        .inactive-session {
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: center;
            height: 100%;
            width: 400px;
            margin: 0 auto;
            background-color: var(--color-secondary);
            border-radius: 10px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            padding: 20px;
            gap: 5px;

            h3 {
                font-size: 1.5rem;
            }

            p {
                font-size: 1.2rem;
                color: var(--color-text);
            }
        }

        #btn-log {
            display: inline-block;
            padding: 10px 20px;
            margin-top: 10px;
            border-radius: 50px;
            border: 1px solid rgba(214, 232, 227, 0.1);
            background-color: var(--color-primary);
            color: var(--color-text);
            font-size: 1.2rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: background-color 0.2s ease-out;
        }

        #btn-log:hover {
            background-color: var(--color-secondary);
        }

        .sesion-control {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .btn-logout {
            background: rgba(26, 43, 34, 0.6);
            border-radius: 50px;
            border: 1px solid rgba(214, 232, 227, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            padding: 10px 24px;
            text-decoration: none;
            color: var(--color-text);
            font-size: 1.2rem;
            font-weight: 500;
            cursor: pointer;
            text-align: center;
            transition: background-color 0.2s ease-out;
        }

        .btn-logout:hover {
            background: rgba(26, 43, 34, 0.8);
        }

        .control-session {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin: 40px 0;
            padding: 0 10px;
        }

        .card-info {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            background: rgba(26, 43, 34, 0.45);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(214, 232, 227, 0.08);
            border-radius: 16px;
            padding: 28px 24px;
            gap: 12px;
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }

        .card-info:hover {
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            border-color: rgba(74, 222, 128, 0.2);
        }

        .card-icon {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(74, 222, 128, 0.1);
            border-radius: 12px;
            margin-bottom: 4px;
        }

        .card-icon svg {
            width: 24px;
            height: 24px;
            stroke: #4ade80;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .card-info h3 {
            font-size: 1.15rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .card-info .card-desc {
            font-size: 0.85rem;
            color: rgba(245, 242, 236, 0.5);
            line-height: 1.4;
        }

        .timer-display {
            font-family: 'Courier New', Courier, monospace;
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: 3px;
            color: #4ade80;
            background: rgba(74, 222, 128, 0.08);
            padding: 10px 22px;
            border-radius: 10px;
            border: 1px solid rgba(74, 222, 128, 0.15);
            min-width: 120px;
        }

        .card-info .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            margin-top: 6px;
            border-radius: 50px;
            border: 1px solid rgba(74, 222, 128, 0.25);
            background: linear-gradient(135deg, rgba(46, 79, 64, 0.8), rgba(26, 43, 34, 0.9));
            color: #4ade80;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .card-info .btn-action:hover {
            background: linear-gradient(135deg, rgba(74, 222, 128, 0.2), rgba(46, 79, 64, 0.8));
            border-color: rgba(74, 222, 128, 0.5);
            box-shadow: 0 0 20px rgba(74, 222, 128, 0.15);
        }

        .card-info .btn-action svg {
            width: 16px;
            height: 16px;
            stroke: #4ade80;
            fill: none;
            stroke-width: 2;
        }

        .expired {
            font-size: 1.2rem;
            background: rgba(239, 68, 68, 0.08);
            border-color: rgba(239, 68, 68, 0.15);
        }
    </style>
</head>

<body>
    <main>
        <section class="welcome">
            <h1>Bienvenido al panel principal</h1>
            <p>Aqui podras gestionar el estado de tu sesion para comprobar el funcionamiento de los tokens</p>
        </section>

        <section class="sesion-control">
            <div class="state-session">
                <p>Estado de la sesion
                    <span id="state">
                        <% if(session) { %>Activa
                            <% } else { %>Inactiva<% } %>
                    </span>
                </p>
            </div>
            <% if(session) { %>
                <button class="btn-logout" onclick="logout()">Cerrar sesion</button>
                <% } %>
        </section>

        <div class="ct">
            <% if(!session) { %>
                <section class="inactive-session">
                    <h3>Parece que no tienes una sesion activa</h3>
                    <p>Inicia sesion para poder acceder a las funcionalidades de la pagina</p>
                    <a id="btn-log" href="/login">Iniciar sesion</a>
                </section>
                <% } %>
        </div>


        <% if(session) { %>
            <section class="control-session">
                <div class="card-info">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                    </div>
                    <h3>Token de acceso</h3>
                    <p class="card-desc">Tiempo restante del token de acceso</p>
                    <p class="timer-display" id="accessToken">00:00</p>
                </div>
                <div class="card-info">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24">
                            <polyline points="23 4 23 10 17 10" />
                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                        </svg>
                    </div>
                    <h3>Token de refresco</h3>
                    <p class="card-desc">Tiempo restante del token de refresco</p>
                    <p class="timer-display" id="refreshToken">00:00</p>
                </div>
                <div class="card-info">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                    </div>
                    <h3>Acciones</h3>
                    <p class="card-desc">Accede a recursos que requieren autenticación</p>
                    <a class="btn-action" href="/protected">
                        <svg viewBox="0 0 24 24">
                            <path d="M5 12h14" />
                            <path d="M12 5l7 7-7 7" />
                        </svg>
                        Contenido protegido
                    </a>
                </div>
            </section>
            <% } %>
    </main>

</body>

</html>