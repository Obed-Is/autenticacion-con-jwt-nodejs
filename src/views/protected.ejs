<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zona Protegida - Aprende sobre JWT</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --color-primary: #2E4F40;
            --color-secondary: #1a2b22;
            --color-text: #F5F2EC;
            --color-text-dim: rgba(245, 242, 236, 0.6);
            --color-accent: #4ade80;
            --card-bg: rgba(26, 43, 34, 0.8);
            --border-color: rgba(214, 232, 227, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Outfit', 'Segoe UI', sans-serif;
        }

        body {
            background: linear-gradient(to right, var(--color-primary), var(--color-secondary));
            color: var(--color-text);
            line-height: 1.6;
            min-height: 100vh;
        }

        .container {
            max-width: 900px;
            margin: auto;
            padding: 40px 20px;
        }

        header {
            text-align: center;
            margin-bottom: 50px;
        }

        h1 {
            font-size: 2.8rem;
            margin-bottom: 10px;
            color: var(--color-accent);
        }

        .welcome-msg {
            font-size: 1.1rem;
            color: var(--color-text-dim);
        }

        .nav-links {
            margin-top: 30px;
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        .nav-links a {
            color: var(--color-text);
            text-decoration: none;
            font-weight: 600;
            padding: 10px 24px;
            border-radius: 50px;
            background: rgba(46, 79, 64, 0.5);
            border: 1px solid var(--border-color);
            transition: 0.2s;
        }

        .nav-links a:hover {
            background: var(--color-primary);
        }

        .blog-section {
            display: grid;
            gap: 25px;
        }

        .btn-logout {
            background: rgba(46, 79, 64, 0.5);
            border-radius: 50px;
            border: 1px solid rgba(214, 232, 227, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            padding: 10px 24px;
            text-decoration: none;
            color: var(--color-text);
            font-size: 1.2rem;
            font-weight: 500;
            cursor: pointer;
            text-align: center;
            transition: background-color 0.2s ease-out;
        }

        .btn-logout:hover {
            background: rgba(26, 43, 34, 0.8);
        }

        .card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 30px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        h2 {
            font-size: 1.6rem;
            margin-bottom: 18px;
            color: var(--color-accent);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        h2::before {
            content: "";
            width: 4px;
            height: 24px;
            background: var(--color-accent);
            border-radius: 2px;
        }

        p {
            margin-bottom: 15px;
            color: var(--color-text-dim);
        }

        strong {
            color: var(--color-text);
        }

        ul,
        ol {
            margin-left: 20px;
            margin-bottom: 15px;
            color: var(--color-text-dim);
        }

        li {
            margin-bottom: 10px;
        }

        .token-split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }

        @media(max-width:768px) {
            .token-split {
                grid-template-columns: 1fr;
            }
        }

        .token-card {
            background: rgba(0, 0, 0, 0.2);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }

        .token-card h3 {
            margin-bottom: 8px;
            color: var(--color-text);
        }

        .jwt-parts {
            background: #0a0a0a;
            padding: 20px;
            border-radius: 12px;
            font-family: monospace;
            font-size: 0.9rem;
            margin: 20px 0;
            overflow-x: auto;
            border: 1px solid rgba(255, 255, 255, 0.05);
            line-break: anywhere;
        }

        .red {
            color: #f87171;
        }

        .purple {
            color: #c084fc;
        }

        .blue {
            color: #60a5fa;
        }

        .footer {
            text-align: center;
            margin-top: 60px;
            padding-bottom: 40px;
            color: var(--color-text-dim);
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <div class="container">
        <header>
            <h1>Zona Protegida</h1>
            <p class="welcome-msg">
                Bienvenido, <strong>
                    <%= username %>
                </strong>
            </p>
            <div class="nav-links">
                <a href="/home">Ir al Inicio</a>
                <button class="btn-logout" onclick="logout()">Cerrar sesion</button>
            </div>
        </header>

        <section class="blog-section">
            <div class="card">
                <h2>¿Qué es un JWT?</h2>
                <p>
                    JSON Web Token (JWT) es un estándar abierto (RFC 7519) que permite transmitir información segura
                    entre dos partes usando un objeto JSON.
                </p>
                <p>
                    A diferencia de las sesiones tradicionales, los JWT son <strong>stateless</strong>, lo que significa
                    que el servidor no necesita almacenar información de sesión.
                </p>
            </div>

            <div class="card">
                <h2>Anatomía de un JWT</h2>
                <p>Un JWT tiene tres partes separadas por puntos:</p>
                <div class="jwt-parts">
                    <span class="red">eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.</span>
                    <span class="purple">
                        eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNzQxNzY0OTY4fQ.
                    </span>
                    <span class="blue">n74lWqWQaMwg_DjkDkGcAv4gA2T3YxULFyIif1wiN3s</span>
                </div>
                <ul>
                    <li><strong class="red">Header:</strong> algoritmo de firma.</li>
                    <li><strong class="purple">Payload:</strong> datos del usuario.</li>
                    <li><strong class="blue">Signature:</strong> valida que el token no fue modificado.</li>
                </ul>
            </div>


            <div class="card">
                <h2>Flujo de Autenticación</h2>
                <ol>
                    <li>El usuario envía usuario y contraseña.</li>
                    <li>El servidor valida los datos.</li>
                    <li>Se generan Access Token y Refresh Token.</li>
                    <li>El servidor almacena el Refresh Token hasheado en una base de datos.</li>
                    <li>El servidor envía los tokens como cookies seguras.</li>
                    <li>El navegador envía los tokens automáticamente en cada petición(request).</li>
                    <li>El servidor verifica el token antes de permitir acceso.</li>
                    <li>Si el token es invalido, se deniega el acceso.</li>
                </ol>
            </div>


            <div class="card">
                <h2>Doble Token: Access vs Refresh</h2>
                <div class="token-split">
                    <div class="token-card">
                        <h3>Access Token</h3>
                        <p>
                            Token de corta duración usado en cada petición al servidor.
                        </p>
                    </div>

                    <div class="token-card">
                        <h3>Refresh Token</h3>
                        <p>
                            Token de larga duración usado para generar nuevos Access Tokens.
                        </p>
                    </div>
                </div>
            </div>


            <div class="card">
                <h2>Ejemplo de Payload</h2>
                <p>
                    El payload es un objeto JSON que contiene información sobre el usuario.
                </p>
                <div class="jwt-parts">
                    {
                    "id":25,
                    "username":"obed",
                    "role":"user",
                    "iat":1710000000,
                    "exp":1710000900
                    }
                </div>
            </div>


            <div class="card">
                <h2>JWT en Node.js</h2>
                <p>
                    Para generar un token en Node.js se utiliza la libreria <a
                        href="https://www.npmjs.com/package/jsonwebtoken" target="_blank">jsonwebtoken</a>.
                </p>
                <div class="jwt-parts">
                    <span class="blue">import</span> <span class="red">jwt</span> <span class="blue">from</span> <span
                        class="red">"jsonwebtoken"</span>; <br>

                    <span class="purple">const</span> <span class="red">token</span> = jwt.sign({ id:user.id,
                    username:user.username },
                    process.env.JWT_SECRET, <br>
                    { expiresIn:"15m" });
                </div>
            </div>


            <div class="card">
                <h2>Verificación de Token</h2>
                <p>
                    Manera de verificar un token en Node.js
                </p>
                <div class="jwt-parts">
                    <span class="blue">import</span> <span class="red">jwt</span> <span class="blue">from</span> <span
                        class="red">"jsonwebtoken"</span>; <br>
                    <span class="purple">const</span> <span class="red">token</span> = jwt.verify(token,
                    process.env.JWT_SECRET);
                </div>
                <p>
                    Si el token fue modificado o expiró, la verificación falla automáticamente.
                </p>
            </div>

            <div class="card">
                <h2>Ataques Comunes contra JWT</h2>
                <ul>
                    <li><strong>XSS:</strong> scripts maliciosos pueden robar tokens si están en localStorage.</li>
                    <li><strong>Token Theft:</strong> robo de tokens.</li>
                    <li><strong>Algoritmo none:</strong> aceptar tokens sin firma.</li>
                </ul>
            </div>

            <div class="card">
                <h2>Buenas Prácticas</h2>
                <ul>
                    <li>Usar expiración corta en Access Token.</li>
                    <li>Guardar Refresh Tokens hasheados.</li>
                    <li>Usar cookies HTTPOnly.</li>
                    <li>Usar HTTPS.</li>
                    <li>Implementar rotación de Refresh Tokens.</li>
                </ul>
            </div>
        </section>

        <div class="footer">Información sobre JWT</div>
    </div>

    <script>
        const logout = async () => {
            const alerta = await Swal.fire({
                title: "¿Estas seguro de cerrar sesion?",
                text: "Se cerrara tu sesion actual",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Cerrar sesion",
                cancelButtonText: "Cancelar",
            });

            if (alerta.isConfirmed) {
                const request = await fetch("/logout", {
                    method: "POST",
                });

                if (!request.ok) {
                    await Swal.fire("Error", "Ocurrio un error al cerrar sesion", "error");
                    return;
                }

                localStorage.removeItem('durationAccessToken');
                localStorage.removeItem('durationRefreshToken');
                clearInterval(intervalToken);

                await Swal.fire("Sesion cerrada", "Tu sesion ha sido cerrada correctamente", "success");
                window.location.href = '/home';
            }
        }
    </script>
</body>

</html>